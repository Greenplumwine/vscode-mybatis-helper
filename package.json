{
  "name": "mybatis-helper-vscode",
  "displayName": "Mybatis Helper",
  "description": "%description%",
  "version": "1.0.1",
  "publisher": "Greenplumwine",
  "icon": "static/icon/mybatis-helper-icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/Greenplumwine/vscode-mybatis-helper.git"
  },
  "license": "MIT",
  "engines": {
    "vscode": "^1.93.0"
  },
  "categories": [
    "Programming Languages",
    "Debuggers",
    "Other"
  ],
  "main": "./out/extension.js",
  "l10n": "./l10n",
  "activationEvents": [
    "workspaceContains:**/pom.xml",
    "workspaceContains:**/build.gradle"
  ],
  "extensionDependencies": [
    "redhat.java"
  ],
  "contributes": {
    "commands": [
      {
        "command": "mybatis-helper.showSqlHistory",
        "title": "%command.showSqlHistory.title%",
        "category": "MyBatis Helper",
        "icon": "$(database)"
      },
      {
        "command": "mybatis-helper.jumpToXml",
        "title": "%command.jumpToXml.title%",
        "category": "MyBatis Helper"
      },
      {
        "command": "mybatis-helper.jumpToMapper",
        "title": "%command.jumpToMapper.title%",
        "category": "MyBatis Helper"
      },
      {
        "command": "mybatis-helper.refreshMappings",
        "title": "%command.refreshMappings.title%",
        "category": "MyBatis Helper"
      },
      {
        "command": "mybatis-helper.rebuildIndex",
        "title": "%command.rebuildIndex.title%",
        "category": "MyBatis Helper"
      },
      {
        "command": "mybatis-helper.refreshSQLHistory",
        "title": "%command.refreshSQLHistory.title%",
        "category": "MyBatis Helper",
        "icon": "$(refresh)"
      },
      {
        "command": "mybatis-helper.copySqlFromTree",
        "title": "%command.copySqlFromTree.title%",
        "category": "MyBatis Helper"
      },
      {
        "command": "mybatis-helper.clearSqlHistory",
        "title": "%command.clearSqlHistory.title%",
        "category": "MyBatis Helper",
        "icon": "$(clear-all)"
      },
      {
        "command": "mybatis-helper.showSqlDetail",
        "title": "%command.showSqlDetail.title%",
        "category": "MyBatis Helper"
      },
      {
        "command": "mybatis-helper.openSQLSettings",
        "title": "%command.openSQLSettings.title%",
        "category": "MyBatis Helper",
        "icon": "$(gear)"
      },
      {
        "command": "mybatis-helper.pauseSQLInterceptor",
        "title": "%command.pauseSQLInterceptor.title%",
        "category": "MyBatis Helper",
        "icon": "$(debug-pause)"
      },
      {
        "command": "mybatis-helper.resumeSQLInterceptor",
        "title": "%command.resumeSQLInterceptor.title%",
        "category": "MyBatis Helper",
        "icon": "$(play)"
      },
      {
        "command": "mybatis-helper.generateXmlMethod",
        "title": "%command.generateXmlMethod.title%",
        "category": "MyBatis Helper",
        "icon": "$(add)"
      },
      {
        "command": "mybatis-helper.createMapperXml",
        "title": "%command.createMapperXml.title%",
        "category": "MyBatis Helper",
        "icon": "$(new-file)"
      },
      {
        "command": "mybatis-helper.showPerformanceStats",
        "title": "%command.showPerformanceStats.title%",
        "category": "MyBatis Helper",
        "icon": "$(pulse)"
      },
      {
        "command": "mybatis-helper.showWelcomePage",
        "title": "%command.showWelcomePage.title%",
        "category": "MyBatis Helper",
        "icon": "$(home)"
      },
      {
        "command": "mybatis-helper.configureWizard",
        "title": "%command.configureWizard.title%",
        "category": "MyBatis Helper",
        "icon": "$(gear)"
      },
      {
        "command": "mybatis-helper.validateConfiguration",
        "title": "%command.validateConfiguration.title%",
        "category": "MyBatis Helper",
        "icon": "$(check)"
      },
      {
        "command": "mybatis-helper.diagnose",
        "title": "%command.diagnose.title%",
        "category": "MyBatis Helper",
        "icon": "$(pulse)"
      }
    ],
    "keybindings": [
      {
        "command": "mybatis-helper.jumpToXml",
        "key": "ctrl+alt+j",
        "mac": "cmd+option+j",
        "when": "editorTextFocus && editorLangId == 'java'"
      },
      {
        "command": "mybatis-helper.jumpToMapper",
        "key": "ctrl+alt+x",
        "mac": "cmd+option+x",
        "when": "editorTextFocus && (editorLangId == 'xml' || editorLangId == 'mybatis-xml')"
      },
      {
        "command": "mybatis-helper.generateXmlMethod",
        "key": "ctrl+shift+g",
        "mac": "cmd+shift+g",
        "when": "editorTextFocus && editorLangId == 'java'"
      }
    ],
    "configuration": {
      "type": "object",
      "title": "%configuration.title%",
      "properties": {
        "mybatis-helper.enableCodeLens": {
          "type": "boolean",
          "default": true,
          "description": "%configuration.enableCodeLens.description%"
        },
        "mybatis-helper.fileOpenMode": {
          "type": "string",
          "enum": [
            "useExisting",
            "noSplit",
            "alwaysSplit"
          ],
          "default": "useExisting",
          "description": "%configuration.fileOpenMode.description%"
        },
        "mybatis-helper.customXmlDirectories": {
          "type": "array",
          "default": [],
          "items": {
            "type": "string"
          },
          "description": "%configuration.customXmlDirectories.description%"
        },
        "mybatis-helper.logOutputLevel": {
          "type": "string",
          "enum": [
            "info",
            "debug"
          ],
          "default": "info",
          "description": "%configuration.logOutputLevel.description%"
        },
        "mybatis-helper.nameMatchingRules": {
          "type": "array",
          "default": [
            {
              "name": "%configuration.nameMatchingRules.defaultMapper.name%",
              "enabled": true,
              "javaPattern": "*Mapper",
              "xmlPattern": "${javaName}",
              "description": "%configuration.nameMatchingRules.defaultMapper.description%"
            },
            {
              "name": "%configuration.nameMatchingRules.defaultDao.name%",
              "enabled": true,
              "javaPattern": "*Dao",
              "xmlPattern": "${javaName}",
              "description": "%configuration.nameMatchingRules.defaultDao.description%"
            },
            {
              "name": "%configuration.nameMatchingRules.standardMapper.name%",
              "enabled": true,
              "javaPattern": "*",
              "xmlPattern": "${javaName}",
              "description": "%configuration.nameMatchingRules.standardMapper.description%"
            }
          ],
          "items": {
            "type": "object",
            "properties": {
              "name": {
                "type": "string",
                "description": "%configuration.nameMatchingRules.item.name.description%"
              },
              "enabled": {
                "type": "boolean",
                "description": "%configuration.nameMatchingRules.item.enabled.description%"
              },
              "javaPattern": {
                "type": "string",
                "description": "%configuration.nameMatchingRules.item.javaPattern.description%"
              },
              "xmlPattern": {
                "type": "string",
                "description": "%configuration.nameMatchingRules.item.xmlPattern.description%"
              },
              "description": {
                "type": "string",
                "description": "%configuration.nameMatchingRules.item.description.description%"
              }
            },
            "required": [
              "name",
              "enabled",
              "javaPattern",
              "xmlPattern"
            ]
          },
          "description": "%configuration.nameMatchingRules.description%"
        },
        "mybatis-helper.ignoreSuffixes": {
          "type": "array",
          "default": [
            "Mapper",
            "Dao"
          ],
          "items": {
            "type": "string"
          },
          "description": "%configuration.ignoreSuffixes.description%"
        },
        "mybatis-helper.pathPriority": {
          "type": "object",
          "default": {
            "enabled": true,
            "priorityDirectories": [
              "/src/",
              "/main/",
              "/resources/"
            ],
            "excludeDirectories": [
              "/build/",
              "/target/",
              "/out/",
              "/.git/"
            ]
          },
          "properties": {
            "enabled": {
              "type": "boolean",
              "description": "%configuration.pathPriority.enabled.description%"
            },
            "priorityDirectories": {
              "type": "array",
              "items": {
                "type": "string"
              },
              "description": "%configuration.pathPriority.priorityDirectories.description%"
            },
            "excludeDirectories": {
              "type": "array",
              "items": {
                "type": "string"
              },
              "description": "%configuration.pathPriority.excludeDirectories.description%"
            }
          },
          "description": "%configuration.pathPriority.description%"
        },
        "mybatis-helper.sqlInterceptor.listenMode": {
          "type": "string",
          "enum": [
            "auto",
            "debugConsole",
            "terminal"
          ],
          "enumDescriptions": [
            "%configuration.sqlInterceptor.listenMode.auto%",
            "%configuration.sqlInterceptor.listenMode.debugConsole%",
            "%configuration.sqlInterceptor.listenMode.terminal%"
          ],
          "default": "auto",
          "description": "%configuration.sqlInterceptor.listenMode.description%"
        },
        "mybatis-helper.sqlInterceptor.autoStart": {
          "type": "boolean",
          "default": true,
          "description": "%configuration.sqlInterceptor.autoStart.description%"
        },
        "mybatis-helper.sqlInterceptor.autoScrollBehavior": {
          "type": "string",
          "enum": [
            "always",
            "onlyWhenNotInteracting",
            "never"
          ],
          "enumDescriptions": [
            "%configuration.sqlInterceptor.autoScrollBehavior.always%",
            "%configuration.sqlInterceptor.autoScrollBehavior.onlyWhenNotInteracting%",
            "%configuration.sqlInterceptor.autoScrollBehavior.never%"
          ],
          "default": "onlyWhenNotInteracting",
          "description": "%configuration.sqlInterceptor.autoScrollBehavior.description%"
        },
        "mybatis-helper.sqlInterceptor.builtinRules": {
          "type": "object",
          "default": {
            "mybatis-standard": true,
            "mybatis-debug": true
          },
          "description": "%configuration.sqlInterceptor.builtinRules.description%"
        },
        "mybatis-helper.sqlInterceptor.customRules": {
          "type": "array",
          "default": [],
          "items": {
            "type": "object",
            "properties": {
              "name": {
                "type": "string",
                "description": "%configuration.sqlInterceptor.customRules.item.name.description%"
              },
              "enabled": {
                "type": "boolean",
                "description": "%configuration.sqlInterceptor.customRules.item.enabled.description%"
              },
              "description": {
                "type": "string",
                "description": "%configuration.sqlInterceptor.customRules.item.description.description%"
              },
              "lineMatchRegex": {
                "type": "string",
                "description": "%configuration.sqlInterceptor.customRules.item.lineMatchRegex.description%"
              },
              "sqlExtractRegex": {
                "type": "string",
                "description": "%configuration.sqlInterceptor.customRules.item.sqlExtractRegex.description%"
              },
              "parametersExtractRegex": {
                "type": "string",
                "description": "%configuration.sqlInterceptor.customRules.item.parametersExtractRegex.description%"
              },
              "executionTimeExtractRegex": {
                "type": "string",
                "description": "%configuration.sqlInterceptor.customRules.item.executionTimeExtractRegex.description%"
              },
              "paramParseRegex": {
                "type": "string",
                "description": "%configuration.sqlInterceptor.customRules.item.paramParseRegex.description%"
              }
            },
            "required": [
              "name",
              "enabled",
              "lineMatchRegex",
              "sqlExtractRegex"
            ]
          },
          "description": "%configuration.sqlInterceptor.customRules.description%"
        },
        "mybatis-helper.formatting.sql.dialect": {
          "type": "string",
          "default": "mysql",
          "enum": [
            "mysql",
            "postgresql",
            "oracle",
            "sqlite",
            "tsql",
            "db2"
          ],
          "enumDescriptions": [
            "MySQL/MariaDB",
            "PostgreSQL",
            "Oracle",
            "SQLite",
            "SQL Server (T-SQL)",
            "DB2"
          ],
          "description": "SQL dialect for formatting"
        },
        "mybatis-helper.formatting.sql.keywordCase": {
          "type": "string",
          "default": "upper",
          "enum": [
            "upper",
            "lower",
            "preserve"
          ],
          "enumDescriptions": [
            "Convert keywords to UPPERCASE",
            "Convert keywords to lowercase",
            "Preserve original case"
          ],
          "description": "Case for SQL keywords in formatting"
        },
        "mybatis-helper.formatting.sql.maxLineLength": {
          "type": "number",
          "default": 120,
          "minimum": 40,
          "maximum": 500,
          "description": "Maximum line length for SQL formatting"
        },
        "mybatis-helper.completion.enableSmartCompletion": {
          "type": "boolean",
          "default": true,
          "description": "Enable smart SQL completion in MyBatis XML files"
        },
        "mybatis-helper.showWelcome": {
          "type": "boolean",
          "default": true,
          "description": "Show welcome page on startup"
        }
      }
    },
    "languages": [
      {
        "id": "mybatis-xml",
        "aliases": [
          "MyBatis XML",
          "mybatis-xml"
        ],
        "firstLine": "^\\s*<[\\?\\!]\\s*xml|^\\s*<mapper\\s+namespace|^\\s*<!DOCTYPE\\s+mapper",
        "configuration": "./language-configuration.json",
        "extensions": [
          ".xml"
        ],
        "filenamePatterns": [
          "**/mapper/**/*.xml",
          "**/mappers/**/*.xml",
          "**/mapping/**/*.xml"
        ]
      }
    ],
    "grammars": [
      {
        "language": "mybatis-xml",
        "scopeName": "text.xml.mybatis",
        "path": "./syntaxes/mybatis-xml.tmLanguage.json"
      }
    ],
    "views": {
      "mybatisHelperView": [
        {
          "id": "mybatisSQLHistory",
          "name": "%view.sqlHistory.name%",
          "when": "mybatis-helper.activated",
          "icon": "icons/mybatis.svg",
          "contextualTitle": "%view.sqlHistory.contextualTitle%"
        }
      ]
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "mybatisHelperView",
          "title": "%activitybar.mybatisHelper.title%",
          "icon": "icons/mybatis.svg"
        }
      ]
    },
    "menus": {
      "explorer/context": [
        {
          "command": "mybatis-helper.createMapperXml",
          "when": "resourceExtname == .java",
          "group": "2_workspace@5"
        }
      ],
      "editor/context": [
        {
          "command": "mybatis-helper.generateXmlMethod",
          "when": "editorLangId == java",
          "group": "2_mybatis@1"
        }
      ],
      "view/title": [
        {
          "command": "mybatis-helper.refreshSQLHistory",
          "when": "view == mybatisSQLHistory",
          "group": "navigation@1"
        },
        {
          "command": "mybatis-helper.pauseSQLInterceptor",
          "when": "view == mybatisSQLHistory && mybatis-helper.sqlInterceptorRunning",
          "group": "navigation@2"
        },
        {
          "command": "mybatis-helper.resumeSQLInterceptor",
          "when": "view == mybatisSQLHistory && !mybatis-helper.sqlInterceptorRunning",
          "group": "navigation@2"
        },
        {
          "command": "mybatis-helper.clearSqlHistory",
          "when": "view == mybatisSQLHistory",
          "group": "navigation@3"
        }
      ],
      "view/item/context": [
        {
          "command": "mybatis-helper.copySqlFromTree",
          "when": "view == mybatisSQLHistory && viewItem == sqlQuery",
          "group": "sqlActions@1"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "pnpm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "pnpm run compile && pnpm run lint",
    "lint": "eslint src",
    "test": "vscode-test",
    "test:unit": "jest",
    "test:unit:watch": "jest --watch",
    "test:unit:coverage": "jest --coverage"
  },
  "devDependencies": {
    "@types/jest": "^29.5.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@types/vscode": "^1.93.0",
    "@typescript-eslint/eslint-plugin": "^8.39.0",
    "@typescript-eslint/parser": "^8.39.0",
    "@vscode/test-cli": "^0.0.11",
    "@vscode/test-electron": "^2.5.2",
    "eslint": "^9.32.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.0",
    "typescript": "^5.9.2"
  },
  "dependencies": {
    "@vscode/codicons": "^0.0.45",
    "axios": "^1.13.6",
    "fast-xml-parser": "^5.3.4",
    "sql-formatter": "^15.7.2",
    "xml-formatter": "^3.6.7"
  }
}